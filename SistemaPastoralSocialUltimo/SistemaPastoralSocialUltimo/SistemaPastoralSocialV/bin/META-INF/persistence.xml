<?xml version="1.0" encoding="UTF-8"?>
<persistence version="2.0"
    xmlns="http://java.sun.com/xml/ns/persistence"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="http://java.sun.com/xml/ns/persistence http://java.sun.com/xml/ns/persistence/persistence_2_0.xsd">
    <persistence-unit name="SistemaPastoralSocial" transaction-type="RESOURCE_LOCAL">
        <class>entidades.Parroquia</class>
        <class>entidades.Usuario</class>
        <class>entidades.AsistenciaSolicitada</class>
        <class>entidades.DatosVivienda</class>
        <class>entidades.Formulario</class>
        <class>entidades.PersonaParticipante</class>
        <class>entidades.AdendumExpediente</class>
        <class>entidades.PagoMensualDetalle</class>
        <properties>
            <property name="javax.persistence.jdbc.url" value="jdbc:mysql://localhost:3306/pastoraldb"/>
            <property name="javax.persistence.jdbc.user" value="root"/>
            <property name="javax.persistence.jdbc.password" value="Villamontero2018"/>
            <property name="javax.persistence.jdbc.driver" value="com.mysql.cj.jdbc.Driver"/>
            <property name="hibernate.hbm2ddl.auto" value="update"/>
            <property name="hibernate.dialect" value="org.hibernate.dialect.MySQL8Dialect"/>
        </properties>
    </persistence-unit>
</persistence>
